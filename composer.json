    "description": "Multi-tenant WhatsApp ordering bot + business admin panel (SaaS).",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "filament/filament": "^3.2",
        "predis/predis": "^2.2",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/horizon": "^5.0",
        "openai-php/laravel": "^0.10"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.26"
